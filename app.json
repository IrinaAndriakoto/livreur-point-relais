{
  "expo": {
    "name": "livreur-point-relais",
    "slug": "livreur-point-relais",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/cube.png",
    "scheme": "livreurpointrelais",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash_screen.png",
      "resizeMode": "cover",
      "backgroundColor": "#0b2f5c"
    },
    "ios": {
      "icon": "./assets/expo.icon"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.irinaandriakoto.livreurpointrelais"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/cube.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash_screen.png",
          "resizeMode": "cover",
          "backgroundColor": "#0b2f5c",
          "dark": {
            "image": "./assets/splash_screen.png",
            "backgroundColor": "#0b2f5c"
          },
          "android": {
            "image": "./assets/splash_screen.png"
          }
        }
      ],
      "expo-font",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "b0010b9d-0aea-44d5-b47e-3789c87ac68e"
      }
    }
  }
}
